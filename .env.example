# Copy this file to .env and fill in your email credentials

# Naver Mail
NAVER_EMAIL=yourid@naver.com
NAVER_APP_PASSWORD=your_app_password_here
# Optional
NAVER_IMAP_HOST=imap.naver.com
NAVER_IMAP_PORT=993
NAVER_MAILBOX=INBOX

# Gmail (use App Password; requires 2-Step Verification)
GMAIL_EMAIL=yourid@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_MAILBOX=INBOX

# Gmail Mail (App Password preferred)
GMAIL_EMAIL=yourid@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
# Optional
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_MAILBOX=INBOX

# Optional: add more Gmail accounts
#GMAIL_EMAIL_2=your-second@gmail.com
#GMAIL_APP_PASSWORD_2=your_second_app_password
# Optional per account overrides
#GMAIL_IMAP_HOST_2=imap.gmail.com
#GMAIL_IMAP_PORT_2=993
#GMAIL_MAILBOX_2=INBOX
#
# Alternative batch format (same index-wise split with commas):
#GMAIL_EMAILS=yourid@gmail.com,your-second@gmail.com
#GMAIL_APP_PASSWORDS=pass1,pass2
